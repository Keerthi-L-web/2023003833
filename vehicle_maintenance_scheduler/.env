# Server Configuration
PORT=3000
NODE_ENV=development

# Authentication Credentials for Evaluation Service
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
ACCESS_TOKEN=your_static_access_token_here

# API Endpoints
DEPOTS_API_URL=https://api.mockservice.io/depots
TASKS_API_URL=https://api.mockservice.io/tasks
EVALUATION_AUTH_URL=https://api.mockservice.io/oauth/token
LOGGING_API_URL=https://api.mockservice.io/logs

# Feature Toggles
# If set to true, the application will use built-in mock data if external API requests fail.
USE_MOCK_FALLBACK=true
